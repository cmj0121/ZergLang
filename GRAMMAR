# The Zerg Programming Language Specification
#
# Author: 2026 <cmj@cmj.tw>
#
# This document defines the syntax and semantics of the Zerg programming language.
#
# The syntax is specified using Extended Backus-Naur Form (EBNF), which provides a
# formal way to describe the structure of Zerg programs, and the `PROGRAM` is the
# starting point for parsing Zerg source code.
PROGRAM      ::= STATEMENTS EOF
STATEMENTS   ::= ( STATEMENT | COMMENT )*
STATEMENT    ::= FOR_STMT | IF_STMT | MATCH_STMT | FN_STMT | SIMPLE_STMT NEWLINE
SIMPLE_STMT  ::= 'nop' | EXPRESSION

# Block
# -----
# A unified block structure used by all compound statements (for, if, fn, match).
# All block items are allowed syntactically; semantic analysis validates context
# (e.g., break/continue only inside for loops, return only inside functions).
BLOCK        ::= '{' BLOCK_ITEM* '}'
BLOCK_ITEM   ::= STATEMENT | CONDI_FLOW | RETURN_STMT | COMMENT

# Control Flow - Loop
# -------------------
# Loop statements with break and continue support.
#   - for { ... }              Infinite loop
#   - for x in EXPR { ... }    Iteration loop
# CONDI_FLOW (break/continue) is only valid inside loop context.
FOR_STMT     ::= 'for' (IDENTIFIER 'in' EXPRESSION)? BLOCK
CONDI_FLOW   ::= ('break' | 'continue') NEWLINE

# Control Flow - If Statement
# ---------------------------
# Conditional execution with optional else branch.
#   - if EXPR { ... }
#   - if EXPR { ... } else { ... }
IF_STMT      ::= 'if' EXPRESSION BLOCK ('else' BLOCK)?

# Pattern Matching
# ----------------
# Match expression against patterns with Rust-style syntax.
#   - match EXPR { PATTERN => { ... } }
#   - match EXPR { PATTERN => STMT }
# Patterns: literals or wildcard (_). The _ wildcard matches any value.
MATCH_STMT   ::= 'match' EXPRESSION '{' MATCH_ARM+ '}'
MATCH_ARM    ::= PATTERN '=>' MATCH_BODY
PATTERN      ::= '_' | LITERAL
MATCH_BODY   ::= BLOCK | SIMPLE_STMT NEWLINE

# Function Definition
# -------------------
# Function with typed parameters and optional return type.
#   - fn name(a: int, b: int) -> int { ... }
#   - fn name() { ... }
# RETURN_STMT is only valid inside function context.
FN_STMT      ::= 'fn' IDENTIFIER '(' PARAMS? ')' RETURN_TYPE? BLOCK
PARAMS       ::= PARAM (',' PARAM)*
PARAM        ::= IDENTIFIER ':' TYPE
RETURN_TYPE  ::= '->' TYPE
TYPE         ::= IDENTIFIER
RETURN_STMT  ::= 'return' EXPRESSION? NEWLINE

# Expression Grammar
# ------------------
# Each level references the next higher precedence level.
# Precedence (high to low): LITERAL → PRIMARY → UNARY → POW → MUL → ADD → SHIFT →
#                           COMPARE → NOT → BIT_AND → BIT_XOR → BIT_OR → AND → XOR → OR → ASSIGN
EXPRESSION   ::= ASSIGNMENT | OR_EXPR

# Assignment (right-associative)
ASSIGNMENT   ::= IDENTIFIER ':=' EXPRESSION

# Logical Operators (left-associative, short-circuit evaluation)
OR_EXPR      ::= XOR_EXPR ('or' XOR_EXPR)*
XOR_EXPR     ::= AND_EXPR ('xor' AND_EXPR)*
AND_EXPR     ::= BIT_OR_EXPR ('and' BIT_OR_EXPR)*

# Bitwise Operators
BIT_OR_EXPR  ::= BIT_XOR_EXPR ('|' BIT_XOR_EXPR)*
BIT_XOR_EXPR ::= BIT_AND_EXPR ('^' BIT_AND_EXPR)*
BIT_AND_EXPR ::= NOT_EXPR ('&' NOT_EXPR)*

# Logical NOT (lower precedence than comparison)
# This allows `not 1 == 2` to parse as `not (1 == 2)` instead of `(not 1) == 2`
NOT_EXPR     ::= 'not' NOT_EXPR | COMPARISON

# Comparison Operators
COMPARISON   ::= SHIFT_EXPR (('==' | '!=' | '<' | '>' | '<=' | '>=') SHIFT_EXPR)?

# Arithmetic Operators
SHIFT_EXPR   ::= ADD_EXPR (('<<' | '>>') ADD_EXPR)*
ADD_EXPR     ::= MUL_EXPR (('+' | '-') MUL_EXPR)*
MUL_EXPR     ::= POW_EXPR (('*' | '/' | '//' | '%') POW_EXPR)*
POW_EXPR     ::= UNARY ('**' UNARY)?

# Unary Operators (high precedence: bitwise NOT, negation)
UNARY        ::= ('~' | '-') UNARY | PRIMARY

# Primary Expressions (grouping and atomic values)
PRIMARY      ::= '(' EXPRESSION ')' | LITERAL


# Lexical Elements
# -----------------
# The following lexical elements are defined for Zerg:
#
#   - EOF           Indicates the end of the source code.
#   - NEWLINE       The end of a line in the source code.
#   - WHITESPACE    Spaces and tabs used to separate tokens (skipped).
#   - COMMENT       Human-readable annotations in the source code.
#   - KEYWORD       Reserved words (nop, nil, true, false).
#   - LITERAL       Atomic values: NUMBER, STRING, KEYWORD, or IDENTIFIER.
#   - OPERATOR      Symbols for operations (assignment, comparison, etc.).

EOF           ::= <end of file>
NEWLINE       ::= '\n' | '\r\n'
WHITESPACE    ::= ' ' | '\t'
COMMENT       ::= '#' <any character except NEWLINE>* (NEWLINE | EOF)

# Keywords
# --------
# Reserved words matched before IDENTIFIER. The lexer must check if an
# IDENTIFIER pattern matches a keyword and emit the keyword token instead.
#
# Value keywords:    nop, nil, true, false
# Logical keywords:  not, and, or, xor
# Control keywords:  for, in, break, continue, return, if, else, match
# Function keywords: fn
# Special keywords:  _

LITERAL       ::= NUMBER | STRING | 'nil' | 'true' | 'false' | IDENTIFIER

# Operators
# ---------
# Symbols used for operations. Multi-character operators must be matched
# before single-character ones (e.g., ':=' before ':').
#
# Lexer Priority (match longest first):
#   =>  before  =
#   **  before  *
#   //  before  /
#   <<  before  <
#   >>  before  >
#   <=  before  <
#   >=  before  >
#   ==  before  =
#   :=  before  :
#
# Parser Precedence (highest to lowest):
#   1. ()                        - Grouping
#   2. []                        - Index
#   3. **                        - Power (right-associative)
#   4. ~ -                       - Unary (bitwise NOT, negation)
#   5. * / // %                  - Multiplicative
#   6. + -                       - Additive
#   7. << >>                     - Shift
#   8. == != < > <= >=           - Comparison
#   9. not                       - Logical NOT
#  10. &                         - Bitwise AND
#  11. ^                         - Bitwise XOR
#  12. |                         - Bitwise OR
#  13. and                       - Logical AND
#  14. xor                       - Logical XOR
#  15. or                        - Logical OR
#  16. :=                        - Assignment (right-associative)
#

# Character Classes
# -----------------
# Lexical patterns that define how source text is tokenized.
#
#  - NUMBER        Numeric literals (decimal, hex, octal, binary, float).
#  - STRING        Text literals (simple and multiline).
#  - IDENTIFIER    Names for variables, functions, and other entities.
NUMBER          ::= FLOAT | HEX_NUMBER | OCT_NUMBER | BIN_NUMBER | DEC_NUMBER
STRING          ::= MULTILINE_STR | SIMPLE_STR
IDENTIFIER      ::= LETTER ( LETTER | DIGIT )*

DEC_NUMBER      ::= DEC_DIGITS
HEX_NUMBER      ::= '0x' HEX_DIGITS
OCT_NUMBER      ::= '0o' OCT_DIGITS
BIN_NUMBER      ::= '0b' BIN_DIGITS
FLOAT           ::= DEC_DIGITS '.' DEC_DIGITS EXPONENT?
EXPONENT        ::= ('e' | 'E') ('+' | '-')? DEC_DIGITS
DEC_DIGITS      ::= DIGIT ('_'? DIGIT)*
HEX_DIGITS      ::= HEX ('_'? HEX)*
OCT_DIGITS      ::= OCT ('_'? OCT)*
BIN_DIGITS      ::= BIN ('_'? BIN)*
OCT             ::= '0'..'7'
BIN             ::= '0' | '1'

SIMPLE_STR      ::= '"' STRING_CHAR* '"'
MULTILINE_STR   ::= '"""' MULTILINE_CHAR* '"""'
STRING_CHAR     ::= ESCAPE_SEQ | PLAIN_CHAR
PLAIN_CHAR      ::= <any character except '"', '\', and NEWLINE>
MULTILINE_CHAR  ::= ESCAPE_SEQ | MULTILINE_PLAIN
MULTILINE_PLAIN ::= <any character except '\' and '"""'>
ESCAPE_SEQ      ::= '\\' ESCAPE_CODE
ESCAPE_CODE     ::= '"' | '\\' | 'n' | 'r' | 't' | '0' | HEX_BYTE
HEX_BYTE        ::= 'x' HEX HEX
HEX             ::= DIGIT | 'a'..'f' | 'A'..'F'

LETTER          ::= 'a'..'z' | 'A'..'Z' | '_'
DIGIT           ::= '0'..'9'
